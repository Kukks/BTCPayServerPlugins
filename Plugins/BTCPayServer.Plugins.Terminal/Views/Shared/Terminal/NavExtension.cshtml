@using BTCPayServer.Client
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using BTCPayServer.Services.Apps
@using BTCPayServer
@using BTCPayServer.Plugins.Terminal
@inject AppService AppService;
@model BTCPayServer.Components.MainNav.MainNavViewModel
@{
    var store = Context.GetStoreDataOrNull();
}

@if (store != null)
{
    var appType = AppService.GetAppType(TerminalApp.AppType)!;
    <li class="nav-item" permission="@Policies.CanModifyStoreSettings">
        <a layout-menu-item="CreateApp-@appType.Type" asp-area="" asp-controller="UIApps" asp-action="CreateApp" asp-route-storeId="@store.Id" asp-route-appType="@appType.Type" id="@($"StoreNav-Create{appType.Type}")">
            <vc:icon symbol="pos-cart" />
            <span>@appType.Description</span>
        </a>
    </li>
    @foreach (var app in Model.Apps.Where(app => app.AppType == appType.Type))
    {
        <li class="nav-item nav-item-sub" permission="@Policies.CanModifyStoreSettings">
            <a layout-menu-item="@nameof(TerminalPlugin)-@app.Id" asp-area="" asp-controller="UITerminal" asp-action="UpdateSettings" asp-route-appId="@app.Id" id="@($"StoreNav-App-{app.Id}")">
                <span>@app.AppName</span>
            </a>
        </li>
    }
}
