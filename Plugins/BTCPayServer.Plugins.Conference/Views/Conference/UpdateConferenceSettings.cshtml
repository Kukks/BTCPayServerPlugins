@using BTCPayServer.Plugins.Conference
@using BTCPayServer.Plugins.Conference.ViewModels
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer
@using BTCPayServer.Abstractions.Models
@using BTCPayServer.Services.Apps
@model ConferenceSettingsViewModel
@{
    var appId = Model.AppId;
    var storeId = Context.GetCurrentStoreId();
    var activeTab = Context.Request.Query["tab"].FirstOrDefault();
    ViewData.SetLayoutModel(new LayoutModel($"{nameof(ConferencePlugin)}-{appId}", "Conference: " + Model.AppName));
}

<div class="sticky-header-setup"></div>
<div class="sticky-header d-sm-flex align-items-center justify-content-between">
    <h2 class="mb-0">@ViewData["Title"]</h2>
</div>

<partial name="_StatusMessage" />

<ul class="nav nav-tabs mb-4" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link @(activeTab is not ("merchants" or "reports") ? "active" : "")" data-bs-toggle="tab" data-bs-target="#settings-tab" type="button" role="tab">Settings</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(activeTab == "merchants" ? "active" : "")" data-bs-toggle="tab" data-bs-target="#merchants-tab" type="button" role="tab">
            Merchants
            @if (Model.Merchants.Count > 0)
            {
                <span class="badge bg-light text-dark ms-1">@Model.Merchants.Count</span>
            }
        </button>
    </li>
    @if (Model.Merchants.Any(m => m.IsProvisioned))
    {
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "reports" ? "active" : "")" data-bs-toggle="tab" data-bs-target="#reports-tab" type="button" role="tab">Reports</button>
        </li>
    }
</ul>

<div class="tab-content">
    <!-- Settings Tab -->
    <div class="tab-pane fade @(activeTab is not ("merchants" or "reports") ? "show active" : "")" id="settings-tab" role="tabpanel">
        <form method="post" asp-action="UpdateSettings" asp-route-appId="@appId">
            <div class="row">
                <div class="col-xl-8 col-xxl-constrain">
                    <div class="form-group">
                        <label asp-for="DefaultLightningConnectionString" class="form-label">Default Lightning Connection String</label>
                        <input asp-for="DefaultLightningConnectionString" class="form-control" placeholder="type=..." />
                        <div class="form-text">Used for merchants without their own connection string. Use "Internal Node" for the server's internal node.</div>
                    </div>
                    <div class="form-group">
                        <label asp-for="DefaultCurrency" class="form-label" data-required>Default Currency</label>
                        <input asp-for="DefaultCurrency" class="form-control" required />
                    </div>
                    <div class="form-group">
                        <label asp-for="DefaultSpread" class="form-label">Default Spread (%)</label>
                        <input asp-for="DefaultSpread" class="form-control" type="number" step="0.01" min="0" max="100" />
                        <div class="form-text">Exchange rate spread applied to all merchant stores by default.</div>
                    </div>
                    <button type="submit" class="btn btn-primary mt-2">Save Settings</button>
                </div>
            </div>
        </form>

        @if (Model.Merchants.Any(m => m.IsProvisioned))
        {
            <hr class="my-4" />
            <h4>Re-apply Settings to All Stores</h4>
            <form method="post" asp-action="ReapplySettings" asp-route-appId="@appId">
                <div class="row">
                    <div class="col-xl-8 col-xxl-constrain">
                        <p class="text-muted">Push conference-level defaults to all provisioned merchant stores. Per-merchant overrides will be respected unless you select "force".</p>
                        <div class="form-check mb-2">
                            <input type="checkbox" class="form-check-input" name="reapplyLightning" value="true" id="reapplyLightning" />
                            <label class="form-check-label" for="reapplyLightning">Lightning Connection String</label>
                        </div>
                        <div class="form-check mb-2">
                            <input type="checkbox" class="form-check-input" name="reapplyCurrency" value="true" id="reapplyCurrency" />
                            <label class="form-check-label" for="reapplyCurrency">Currency</label>
                        </div>
                        <div class="form-check mb-2">
                            <input type="checkbox" class="form-check-input" name="reapplySpread" value="true" id="reapplySpread" />
                            <label class="form-check-label" for="reapplySpread">Spread</label>
                        </div>
                        <button type="submit" class="btn btn-warning mt-2">Re-apply Selected</button>
                    </div>
                </div>
            </form>
        }
    </div>

    <!-- Merchants Tab -->
    <div class="tab-pane fade @(activeTab == "merchants" ? "show active" : "")" id="merchants-tab" role="tabpanel">
        @if (Model.Merchants.Any(m => !m.IsProvisioned))
        {
            <div class="mb-4">
                <form method="post" asp-action="ProvisionAll" asp-route-appId="@appId" class="d-inline">
                    <button type="submit" class="btn btn-success">Provision All</button>
                </form>
            </div>
        }

        <form method="post" asp-action="AddMerchant" asp-route-appId="@appId" id="addMerchantsForm">
            <div class="table-responsive">
                <table class="table table-hover">
                    @if (Model.Merchants.Count > 0)
                    {
                        <thead>
                            <tr>
                                <th>Email</th>
                                <th>Store Name</th>
                                <th>Currency</th>
                                <th>Spread</th>
                                <th>Status</th>
                                <th>POS</th>
                                <th>Login</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var merchant in Model.Merchants)
                            {
                                <tr class="@(merchant.HasError ? "table-danger" : "")">
                                    <td>@merchant.Email</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(merchant.StoreId))
                                        {
                                            <a asp-controller="UIStores" asp-action="Dashboard" asp-route-storeId="@merchant.StoreId">@merchant.StoreName</a>
                                        }
                                        else
                                        {
                                            @merchant.StoreName
                                        }
                                    </td>
                                    <td>@(merchant.Currency ?? "Default")</td>
                                    <td>@(merchant.Spread?.ToString("0.##") ?? "Default")%</td>
                                    <td>
                                        @if (merchant.HasError)
                                        {
                                            <span class="badge text-bg-danger">@merchant.Status</span>
                                        }
                                        else if (merchant.IsProvisioned)
                                        {
                                            <span class="badge text-bg-success">@merchant.Status</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-warning">@merchant.Status</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(merchant.PosLink))
                                        {
                                            <a href="@merchant.PosLink" target="_blank">Link</a>
                                            <span class="text-muted mx-1">·</span>
                                            <a href="#" data-bs-toggle="modal" data-bs-target="#posQrModal-@merchant.PosAppId">QR</a>
                                        }
                                    </td>
                                    <td>
                                        @if (merchant.CanGenerateLoginCode)
                                        {
                                            <a href="#" class="login-code-btn"
                                               data-bs-toggle="modal" data-bs-target="#loginCodeModal"
                                               data-email="@merchant.Email"
                                               data-store-name="@merchant.StoreName">Login</a>
                                        }
                                        else if (merchant.IsExistingUser)
                                        {
                                            <span class="text-muted" title="Login codes are disabled for pre-existing accounts for security reasons.">N/A</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        @if (!merchant.IsProvisioned && !merchant.HasError)
                                        {
                                            <form method="post" asp-action="ProvisionMerchant" asp-route-appId="@appId" class="d-inline">
                                                <input type="hidden" name="email" value="@merchant.Email" />
                                                <button type="submit" class="btn btn-link btn-sm p-0 text-success">Provision</button>
                                            </form>
                                        }
                                        @if (merchant.HasError)
                                        {
                                            <form method="post" asp-action="RepairMerchant" asp-route-appId="@appId" class="d-inline">
                                                <input type="hidden" name="email" value="@merchant.Email" />
                                                <button type="submit" class="btn btn-link btn-sm p-0 text-warning">Repair</button>
                                            </form>
                                        }
                                        @{var editBtnModalId = merchant.Email.Replace("@@", "_").Replace(".", "_").Replace("+", "_");}
                                        <a href="#" data-bs-toggle="modal" data-bs-target="#editMerchant-@editBtnModalId">Edit</a>
                                        <span class="text-muted mx-1">·</span>
                                        <form method="post" asp-action="RemoveMerchant" asp-route-appId="@appId" class="d-inline"
                                              onsubmit="return confirm('Remove this merchant? Their store will be archived.');">
                                            <input type="hidden" name="email" value="@merchant.Email" />
                                            <button type="submit" class="btn btn-link btn-sm p-0 text-danger">Remove</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    }
                    <tbody id="merchantRows"></tbody>
                    <tfoot>
                        <tr>
                            <td colspan="@(Model.Merchants.Count > 0 ? 8 : 1)">
                                <button type="button" class="btn btn-link btn-sm p-0" id="addMerchantRow">+ Add Row</button>
                                <button type="submit" class="btn btn-primary btn-sm ms-2 d-none" id="addMerchantSubmit">Add</button>
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </form>

        <div class="d-flex gap-2 align-items-center mt-2 mb-3">
            <form method="post" asp-action="ImportCsv" asp-route-appId="@appId" enctype="multipart/form-data" class="d-flex gap-2 align-items-center">
                <input type="file" name="file" accept=".csv" class="form-control form-control-sm" style="max-width: 220px;" />
                <button type="submit" class="btn btn-link btn-sm p-0">Import CSV</button>
            </form>
            <a asp-action="DownloadCsvTemplate" asp-route-appId="@appId" class="btn btn-link btn-sm p-0">Template</a>
        </div>

        <!-- Edit Modals -->
        @foreach (var merchant in Model.Merchants)
        {
            var editModalId = merchant.Email.Replace("@@", "_").Replace(".", "_").Replace("+", "_");
            <div class="modal fade" id="editMerchant-@editModalId" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form method="post" asp-action="UpdateMerchant" asp-route-appId="@appId">
                            <input type="hidden" name="email" value="@merchant.Email" />
                            <div class="modal-header">
                                <h5 class="modal-title">Edit @merchant.Email</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <div class="form-group">
                                    <label class="form-label">Store Name</label>
                                    <input type="text" name="StoreName" class="form-control" value="@merchant.StoreName" required />
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Currency (leave blank for default)</label>
                                    <input type="text" name="Currency" class="form-control" value="@merchant.Currency" />
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Spread %</label>
                                    <input type="number" name="Spread" class="form-control" step="0.01" min="0" max="100" value="@merchant.Spread" />
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Lightning Connection String (leave blank for default)</label>
                                    <input type="text" name="LightningConnectionString" class="form-control" value="@merchant.LightningConnectionString" />
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary">Save</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }

        <!-- POS QR Modals -->
        @foreach (var merchant in Model.Merchants.Where(m => !string.IsNullOrEmpty(m.PosLink)))
        {
            <div class="modal fade" id="posQrModal-@merchant.PosAppId" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">@merchant.StoreName - POS QR</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body text-center">
                            <vc:qr-code data="@($"{Context.Request.Scheme}://{Context.Request.Host}{merchant.PosLink}")" />
                            <p class="mt-2 text-muted">Scan to open the Point of Sale</p>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Reports Tab -->
    @if (Model.Merchants.Any(m => m.IsProvisioned))
    {
        <div class="tab-pane fade @(activeTab == "reports" ? "show active" : "")" id="reports-tab" role="tabpanel">
            <div class="btn-group mb-4" role="group">
                @foreach (var range in new[] { ReportTimeRange.Today, ReportTimeRange.Yesterday, ReportTimeRange.Last7Days })
                {
                    var label = range switch
                    {
                        ReportTimeRange.Today => "Today",
                        ReportTimeRange.Yesterday => "Yesterday",
                        ReportTimeRange.Last7Days => "Last 7 Days",
                        _ => range.ToString()
                    };
                    <a asp-action="UpdateSettings" asp-route-appId="@appId" asp-route-tab="reports" asp-route-timeRange="@range"
                       class="btn @(Model.SelectedTimeRange == range ? "btn-primary" : "btn-outline-primary")">
                        @label
                    </a>
                }
            </div>

            @if (Model.Report != null)
            {
                <div class="widget store-numbers mb-4">
                    <div class="store-number">
                        <header><h6>Invoices</h6></header>
                        <div class="h3">@Model.Report.TotalInvoices</div>
                    </div>
                    @foreach (var total in Model.Report.TotalsByStoreCurrency)
                    {
                        <div class="store-number">
                            <header><h6>Sales (@total.Key)</h6></header>
                            <div class="h3">@total.Value.ToString("N2") <span class="text-secondary fw-semibold" style="font-size: .65em">@total.Key</span></div>
                        </div>
                    }
                    @if (Model.Report.MerchantReports.Count > 0)
                    {
                        @foreach (var group in Model.Report.MerchantReports
                            .Where(r => r.PaymentBreakdown.Count > 0)
                            .SelectMany(r => r.PaymentBreakdown.Values)
                            .GroupBy(p => p.Currency)
                            .Select(g => new { Currency = g.Key, Total = g.Sum(p => p.TotalAmount) }))
                        {
                            <div class="store-number">
                                <header><h6>Received (@group.Currency)</h6></header>
                                <div class="h3">@group.Total.ToString("N8") <span class="text-secondary fw-semibold" style="font-size: .65em">@group.Currency</span></div>
                            </div>
                        }
                    }
                </div>

                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Email</th>
                                <th>Store Name</th>
                                <th class="text-end">Invoices</th>
                                <th class="text-end">Sales</th>
                                <th class="text-end">Payments</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var merchant in Model.Merchants.Where(m => m.IsProvisioned))
                            {
                                <tr>
                                    <td>@merchant.Email</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(merchant.StoreId))
                                        {
                                            <a asp-controller="UIStores" asp-action="Dashboard" asp-route-storeId="@merchant.StoreId">@merchant.StoreName</a>
                                        }
                                        else
                                        {
                                            @merchant.StoreName
                                        }
                                    </td>
                                    <td class="text-end">@(merchant.MerchantReport?.InvoiceCount ?? 0)</td>
                                    <td class="text-end">
                                        @if (merchant.MerchantReport != null && merchant.MerchantReport.TotalStoreCurrency > 0)
                                        {
                                            @merchant.MerchantReport.TotalStoreCurrency.ToString("N2")
                                            <span class="text-secondary">@merchant.MerchantReport.StoreCurrency</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        @if (merchant.MerchantReport?.PaymentBreakdown?.Count > 0)
                                        {
                                            @foreach (var payment in merchant.MerchantReport.PaymentBreakdown.Values)
                                            {
                                                <span class="d-block">@payment.TotalAmount.ToString("N8") <span class="text-secondary">@payment.Currency</span></span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="fw-bold">
                                <td colspan="2">Total</td>
                                <td class="text-end">@Model.Report.TotalInvoices</td>
                                <td class="text-end">
                                    @foreach (var total in Model.Report.TotalsByStoreCurrency)
                                    {
                                        <span class="d-block">@total.Value.ToString("N2") <span class="text-secondary">@total.Key</span></span>
                                    }
                                </td>
                                <td class="text-end">
                                    @foreach (var group in Model.Report.MerchantReports
                                        .Where(r => r.PaymentBreakdown.Count > 0)
                                        .SelectMany(r => r.PaymentBreakdown.Values)
                                        .GroupBy(p => p.Currency)
                                        .Select(g => new { Currency = g.Key, Total = g.Sum(p => p.TotalAmount) }))
                                    {
                                        <span class="d-block">@group.Total.ToString("N8") <span class="text-secondary">@group.Currency</span></span>
                                    }
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        </div>
    }
</div>

<!-- Shared Login Code Modal (populated via AJAX) -->
<div class="modal fade" id="loginCodeModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="loginCodeModalTitle">Login</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center" id="loginCodeModalBody">
                <div class="spinner-border" role="status"></div>
            </div>
            <div class="modal-footer justify-content-center">
                <button type="button" class="btn btn-outline-primary btn-sm" id="loginCodeRefresh">
                    Refresh Code
                </button>
            </div>
        </div>
    </div>
</div>

<div class="d-grid d-sm-flex flex-wrap gap-3 mt-4">
    <a class="btn btn-secondary" asp-action="ListInvoices" asp-controller="UIInvoice" asp-route-storeId="@storeId">Invoices</a>
    <form method="post" asp-controller="UIApps" asp-action="ToggleArchive" asp-route-appId="@appId">
        <button type="submit" class="w-100 btn btn-outline-secondary" id="btn-archive-toggle">
            <span class="text-nowrap">Archive this app</span>
        </button>
    </form>
    <a id="DeleteApp" class="btn btn-outline-danger" asp-controller="UIApps" asp-action="DeleteApp" asp-route-appId="@appId"
       data-bs-toggle="modal" data-bs-target="#ConfirmModal"
       data-description="The app and its settings will be permanently deleted. Merchant stores will NOT be deleted."
       data-confirm-input="DELETE">Delete this app</a>
</div>

<partial name="_Confirm" model="@(new ConfirmModel("Delete app", "This app will be removed from this store. Merchant stores will NOT be deleted.", "Delete"))" />
<partial name="_ValidationScriptsPartial" />

<script>
(function () {
    var container = document.getElementById('merchantRows');
    var addRowBtn = document.getElementById('addMerchantRow');
    var submitBtn = document.getElementById('addMerchantSubmit');
    if (!container || !addRowBtn) return;

    function createRow() {
        var tr = document.createElement('tr');
        tr.className = 'merchant-row';
        tr.innerHTML =
            '<td><input type="email" name="emails" class="form-control form-control-sm" placeholder="Email" required /></td>' +
            '<td><input type="text" name="storeNames" class="form-control form-control-sm" placeholder="Store Name" required /></td>' +
            '<td><input type="text" name="currencies" class="form-control form-control-sm" placeholder="Default" /></td>' +
            '<td><input type="number" name="spreads" class="form-control form-control-sm" step="0.01" min="0" max="100" placeholder="%" /></td>' +
            '<td colspan="3"><input type="text" name="passwords" class="form-control form-control-sm" placeholder="Password (auto)" /></td>' +
            '<td class="text-end"><a href="#" class="text-danger remove-row">Remove</a></td>';
        tr.querySelector('.remove-row').addEventListener('click', function (e) {
            e.preventDefault();
            tr.remove();
            updateState();
        });
        return tr;
    }

    function updateState() {
        var rows = container.querySelectorAll('.merchant-row');
        if (rows.length === 0) {
            submitBtn.classList.add('d-none');
        } else {
            submitBtn.classList.remove('d-none');
        }
    }

    addRowBtn.addEventListener('click', function () {
        var row = createRow();
        container.appendChild(row);
        updateState();
        row.querySelector('input[name="emails"]').focus();
    });

    var loginModal = document.getElementById('loginCodeModal');
    if (!loginModal) return;

    var modalTitle = document.getElementById('loginCodeModalTitle');
    var modalBody = document.getElementById('loginCodeModalBody');
    var refreshBtn = document.getElementById('loginCodeRefresh');
    var loginCodeUrl = '@Url.Action("GenerateLoginCode", "Conference", new { appId = Model.AppId })';
    var currentEmail = '';
    var currentStoreName = '';

    function fetchLoginCode() {
        modalBody.innerHTML = '<div class="spinner-border" role="status"></div>';
        var form = new FormData();
        form.append('email', currentEmail);
        fetch(loginCodeUrl, { method: 'POST', body: form, headers: { 'RequestVerificationToken': (document.querySelector('input[name="__RequestVerificationToken"]') || {}).value || '' } })
            .then(function (r) {
                if (!r.ok) throw new Error(r.statusText);
                return r.text();
            })
            .then(function (html) { modalBody.innerHTML = html; })
            .catch(function () { modalBody.innerHTML = '<div class="alert alert-danger mb-0">Failed to generate login code</div>'; });
    }

    loginModal.addEventListener('show.bs.modal', function (e) {
        var btn = e.relatedTarget;
        if (!btn) return;
        currentEmail = btn.dataset.email;
        currentStoreName = btn.dataset.storeName;
        modalTitle.textContent = currentStoreName + ' — Login';
        fetchLoginCode();
    });

    refreshBtn.addEventListener('click', fetchLoginCode);
})();
</script>
